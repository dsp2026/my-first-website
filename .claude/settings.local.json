      "Bash(curl -s -o CLAUDE.md https://raw.githubusercontent.com/hw5511/vibe-web/main/docs/CLAUDE.md)",
      "Bash(pkill -f \"vite\")",
      "Bash(netstat -ano)",
      "Bash(tasklist)",
